if SHIELD_FAYTL_DONGLE

config ZMK_KEYBOARD_NAME
    default "FAYTL"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
    default 2

config ZMK_USB
    default y

endif # SHIELD_FAYTL_DONGLE

if SHIELD_FAYTL_LEFT || SHIELD_FAYTL_RIGHT || SHIELD_FAYTL_DONGLE

config ZMK_SPLIT
    default y

config ZMK_BLE
    default y

endif # SHIELD_FAYTL_LEFT || SHIELD_FAYTL_RIGHT || SHIELD_FAYTL_DONGLE
